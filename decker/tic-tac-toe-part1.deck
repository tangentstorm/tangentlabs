{contraption:tutor}
size:[512,128]
resizable:1
margin:[5,35,4,8]
description:"A contraption for creating interactive decker tutorials."
version:0.1
image:"%%"
script:"tutor.0p"
attributes:{"name":["body","code","next","prev"],"label":["body","code","next","prev"],"type":["rich","code","string","string"]}
{widgets}
body:{"type":"field","size":[210,93],"pos":[3,33],"locked":1,"pattern":39,"show":"transparent","border":0,"value":"..."}
nextBtn:{"type":"button","size":[60,20],"pos":[445,35],"script":"tutor.1p","pattern":39,"text":"next>","style":"rect"}
cardName:{"type":"field","size":[504,20],"pos":[3,7],"locked":1,"volatile":1,"font":"menu","show":"transparent","border":0,"style":"plain"}
code:{"type":"field","size":[218,94],"pos":[222,32],"pattern":47,"show":"none","border":1,"style":"code"}
prevBtn:{"type":"button","size":[60,20],"pos":[445,62],"script":"tutor.2p","pattern":39,"text":"<prev","style":"rect"}
runBtn:{"type":"button","size":[60,20],"pos":[445,98],"script":"tutor.3p","pattern":0,"show":"none","text":"run","style":"rect"}
next:{"type":"field","size":[100,20],"pos":[4,-31],"locked":1,"show":"none","style":"plain","value":"Next"}
prev:{"type":"field","size":[100,20],"pos":[121,-31],"locked":1,"show":"none","style":"plain","value":"Prev"}

{script:tutor.0p}
on get_body do body.value end  on set_body x do body.value: x end
on get_code do code.text end   on set_code x do code.text: x end
on get_next do next.text end   on set_next x do next.text: x end
on get_prev do prev.text end   on set_prev x do prev.text: x end

on view do
 cardName.text: deck.card.name
 code.locked: me.locked
 sh: if code.text
       if me.locked "invert" else "solid" end
     else "none" end
 code.show: sh runBtn.show: sh
 # "-" is placeholder awaiting this fix:
 # https://github.com/JohnEarnest/Decker/commit/f591e823a
 nextBtn.show: if next.text "solid" else "none" end
 prevBtn.show: if prev.text "solid" else "none" end
end

on next_card_name do
 if next.text = "Next"
  cn:keys deck.cards
  ci:first extract index where value=deck.card.name from cn
  cn[ci+1]
 else
  next.text
 end
end

on no_script c do
 (c.script="on view do\n\nend") |!c.script
end

on is_special c do
 "special" in keys c.widgets
end

on copy_to_next do
 card: deck.card
 if !is_special[card]
  nc: deck.cards[next_card_name[]]
  if !is_special[nc]
   tw: "tutor1"
   if ! count tw drop nc.widgets
    each w in tw drop card.widgets nc.add[w] end
   end
   if no_script[nc] nc.script: card.script end
  end
 end
end

on run text do
 d:deck.card.widgets
 d.card: deck.card
 eval[text d 1]
end

{end}

{script:tutor.1p}
on click do
 copy_to_next[]
 go[next.text "SlideLeft" 15]
end
{end}

{script:tutor.2p}
on click do
 go[prev.text "SlideRight" 15]
end
{end}

{script:tutor.3p}
on click do
 d:deck.card.widgets
 d.card:deck.card
 eval[code.text d 1]
end

{end}

