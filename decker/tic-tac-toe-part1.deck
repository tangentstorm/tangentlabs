{script:let's make tic tac toe!.0}
# tic-tac-toe

on turn side do
 other: if "cx"=which.text "co" else "cx" end
 which.text: side: other unless side
 each w in cx,co w.show:"none" end
 card.widgets[side].show:"transparent"
end

on click do
 if !me.name in "cx","co"
  t:which.text
  w:card.widgets[t]
  me.clear[]
  me.paste[w.copy[]]
  turn[]
  clearBtn.locked:0
 end
end

{end}

{script:let's make tic tac toe!.1}
on click do
 each w in card.widgets
  if (w.type="canvas") & ! w.name in "cx","co"
    w.clear[]
  end
 end
 turn["cx"]
 me.locked: 1
end

{end}

