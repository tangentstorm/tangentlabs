tutor1:{"type":"contraption","size":[512,160],"pos":[0,190],"def":"tutor","widgets":{"body":{"size":[210,125],"value":"Here's a very simple way to make the game.\n\nRun the script or use the menus to make the canvas widgets draggable.\n\nThen just make copies of the canvases using the Widget tool.\n\nSince there are 9 squares and \"X\" goes first, you may need up to 5 \"X\" and 4 \"O\" symbols. "},"nextBtn":{"size":[60,25],"pos":[445,44]},"cardName":{},"code":{"size":[218,126],"value":"each w in card.widgets\n if \"canvas\"=w.type\n   w.border:0\n   w.locked:1 w.draggable:1\n   w.show:\"transparent\"\n   # erase border on image itself:\n   # w.pattern:0 w.box[0,0 w.size]\n end\nend\n"},"prevBtn":{"size":[60,25],"pos":[445,78]},"runBtn":{"size":[60,25],"pos":[445,123]},"next":{},"prev":{}}}

