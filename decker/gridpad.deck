{card:sprites}
image:"%%"
script:"sprites.0"
{widgets}
gs:{"type":"contraption","size":[129,129],"pos":[28,107],"locked":1,"volatile":1,"script":"sprites.1","show":"transparent","def":"gridpad","widgets":{"cellW":{"pos":[159,-46],"value":8},"cellH":{"pos":[159,-3],"value":8},"c":{"size":[129,129]},"gridColor":{"size":[54,26],"pos":[159,40],"value":1},"curXY":{"pos":[159,82]},"gridW":{"pos":[225,-46]},"gridH":{"pos":[225,-3]},"cursor":{"pos":[226,40]}}}
notes:{"type":"field","size":[452,49],"pos":[24,277],"pattern":42,"style":"plain","value":"Gridpad contraption demo. `pal` draws the palette in its \"draw\" event. Sprite data is stored directly on the card background. "}
pal:{"type":"contraption","size":[129,24],"pos":[28,62],"volatile":1,"script":"sprites.2","def":"gridpad","widgets":{"cellW":{"pos":[159,-46],"value":8},"cellH":{"size":[54,7],"pos":[159,-3],"value":8},"c":{"size":[129,24]},"gridColor":{"size":[54,4],"pos":[159,8],"value":1},"curXY":{"size":[61,4],"pos":[159,15],"value":"[0,2]"},"gridW":{"pos":[225,-46]},"gridH":{"size":[54,7],"pos":[225,-3],"value":3},"cursor":{"size":[60,3],"pos":[226,8]}}}
c:{"type":"canvas","size":[127,127],"pos":[194,108],"locked":1,"volatile":1,"script":"sprites.3","show":"transparent","border":0,"scale":16}
gp:{"type":"contraption","size":[128,128],"pos":[193,107],"volatile":1,"script":"sprites.4","show":"transparent","def":"gridpad","widgets":{"cellW":{},"cellH":{},"c":{"pattern":9},"gridColor":{},"curXY":{"value":"[0,2]"},"gridW":{},"gridH":{},"cursor":{"value":0}}}

{script:sprites.0}
c.scale:gp.cwh

on sprite_to_gp do
 c.paste[card.image.copy[gs.pos + (gs.cwh * gs.cxy) gs.cwh]]
end

on view do sprite_to_gp[] end

{end}

{script:sprites.1}
on pick xy do
 sprite_to_gp[]
end

{end}

{script:sprites.2}
on draw c do
 cwh:me.cwh i:-1
 each xy in me.gw cross me.gh
  c.pattern:i:i+1 c.rect[cwh*xy cwh]
 end
end

{end}

{script:sprites.3}
on click pos do
 
end

on drag pos do
 
end

on release pos do
 
end
{end}

{script:sprites.4}
on pick xy do
 im:card.image
 im[gs.pos + (gs.cxy * gs.cwh) + xy]: pal.cur
 card.image:im
 sprite_to_gp[]
end

{end}

{card:vgafont}
script:"vgafont.0"
{widgets}
font:{"type":"field","size":[264,112],"pos":[16,344],"scroll":194,"value":"%%"}
ord:{"type":"slider","size":[264,16],"pos":[16,56],"script":"vgafont.1","interval":[0,255],"value":153}
glyph:{"type":"canvas","size":[128,256],"pos":[152,80],"script":"vgafont.2","image":"%%IMG3AAgAEAbAl3AoFImGRqLyZWwWj08mVEqNJq3T5JW6vTa3y7B4/AoC","scale":16}
chart:{"type":"canvas","size":[128,256],"pos":[16,80],"locked":1,"script":"vgafont.3","pattern":0,"image":"%%","scale":1}
redraw:{"type":"button","size":[88,24],"pos":[16,464],"script":"vgafont.4","text":"redraw chart"}
do_rnd:{"type":"button","size":[112,24],"pos":[328,56],"script":"vgafont.5","show":"transparent","text":"screen saver","style":"check","value":0}
load:{"type":"button","size":[88,24],"pos":[112,464],"script":"vgafont.6","text":"load vga font"}
button1:{"type":"button","size":[48,24],"pos":[792,56],"script":"vgafont.7","show":"transparent","text":"clear","style":"invisible"}
cursor:{"type":"canvas","size":[8,16],"pos":[88,224],"locked":1,"script":"vgafont.2","border":0,"image":"%%IMG3AAgAEAbAkXAoNJmGRqJyZGwWj08mVEqNJq3T5JW6vTa3y7B4PAoC","scale":1}
term:{"type":"canvas","size":[512,256],"pos":[328,80],"volatile":1,"script":"vgafont.2","border":0,"scale":1}
notes:{"type":"field","size":[452,96],"pos":[24,230],"pattern":42,"style":"plain","value":"this should be updated to use gridPad"}

{script:vgafont.0}
fnt:array[font.text]
cs: 8,16
chart_gs: 16,16
term_gs: 64,16

on cwc c do # colorwrite color
  32+first extract index where value=c from "WKwrRyYGgcCbBMmk"
end

#-- manually draw a character pixel by pixel
on draw cv ch fg bg xy do
 each r y in fnt[(16*ch),16]  m:1
   each x in 7-range 8
     cv[xy+x,y]: if bits.and[m r] fg else bg end
     m:m*2
   end
 end 0
end

on redraw_chart do
 each y in range 16
  each x in range 16
   draw[chart x+y*16 fg:1 bg:0 (x,y)*8,16]
  end
 end
end

on redraw_glyph do
 blit[glyph ord.value fg:cwc.w bg:cwc.k]
 blit[cursor ord.value cwc.Y cwc.r]
end

#-- fast copy and paste with image interface
on cxy ch do   gw:chart_gs[0]  cs*(gw%ch),floor ch/gw  end

on blit cv ch fg bg xy do
 im:chart.copy[cxy[ch] cs].map[(0,1) dict bg,fg]
 cv.paste[im xy]
end

# -- "screen saver" ---
on rnd_xy xy do random[xy[0]],random[xy[1]] end
on rnd do
 each _ in range 256
  blit[term random[256] 32+random[15] 1 cs*rnd_xy[term_gs]]
 end
end

on view do
 if do_rnd.value rnd[] go[card] end
end
{end}

{script:vgafont.1}
on change val do
 cursor.pos: chart.pos+cxy[val]
 redraw_glyph[]
end
{end}

{script:vgafont.2}
on click pos do

end

on drag pos do

end

on release pos do

end
{end}

{script:vgafont.3}
on chart_index xy do
 sum xy * 1,chart_gs[0]
end

on click pos do
 xy: floor pos/cs
 cursor.pos: me.pos + cs*xy
 cursor.size: cs
 ord.value: chart_index[xy]
 redraw_glyph[]
end

on drag pos do click[pos] end
{end}

{script:vgafont.4}
on click do
 redraw_chart[]
end
{end}

{script:vgafont.5}
on click do
 go[card]
end
{end}

{script:vgafont.6}
on click do
 if t: read["array"]
  fnt:t
  font.text:t.encoded
  redraw_font[]
 end
end
{end}

{script:vgafont.7}
on click do
 c:term c.pattern:1
 c.rect[0,0 c.size]
end
{end}

{contraption:gridpad}
size:[128,128]
resizable:1
margin:[2,1,2,2]
description:"Draws a rectangular grid with a cursor, and translates mouse events to grid coordinates."
version:0.1
script:"gridpad.0p"
attributes:{"name":["cw","ch","gc","border","gw","gh","cursor"],"label":["cell width","cell height","grid color","draw border?","grid width","grid height","draw cursor?"],"type":["number","number","number","bool","number","number","bool"]}
{widgets}
cellW:{"type":"slider","size":[54,25],"pos":[158,-46],"locked":1,"interval":[4,100],"value":16,"style":"compact"}
cellH:{"type":"slider","size":[54,25],"pos":[158,-3],"locked":1,"interval":[4,100],"value":16,"style":"compact"}
c:{"type":"canvas","size":[128,128],"pos":[0,0],"locked":1,"volatile":1,"pattern":32,"show":"transparent","border":1,"scale":1}
gridColor:{"type":"slider","size":[54,25],"pos":[158,40],"locked":1,"interval":[0,47],"value":9,"style":"compact"}
curXY:{"type":"field","size":[61,20],"pos":[158,81],"locked":1,"style":"plain","value":"[0,0]"}
gridW:{"type":"slider","size":[54,25],"pos":[224,-46],"locked":1,"interval":[1,1024],"value":16,"style":"compact"}
gridH:{"type":"slider","size":[54,25],"pos":[224,-3],"locked":1,"interval":[1,1024],"value":16,"style":"compact"}
cursor:{"type":"button","size":[60,20],"pos":[225,40],"locked":1,"text":"cursor?","style":"check","value":1}

{script:gridpad.0p}
on get_cw do cellW.value end       on set_cw x do cellW.value: x end
on get_ch do cellH.value end       on set_ch x do cellH.value: x end
on get_gw do gridW.value end       on set_gw x do gridW.value: x end
on get_gh do gridH.value end       on set_gh x do gridH.value: x end
on get_gc do gridColor.value end   on set_gc x do gridColor.value: x end
on get_border do c.border end      on set_border x do c.border:x end
on get_cursor do cursor.value end  on set_cursor x do cursor.value:x end
on get_cxy do curXY.data end       on set_cxy xy do curXY.data: xy end

on get_cwh do cellW.value,cellH.value end
on get_cur do (get_gw[] * last curXY.data) + first curXY.data end

on view do
 c.clear[] c.brush:0
 # give instances a chance to draw on canvas
 card.event["draw" c]
 if c.pattern: gridColor.value
  each x in get_cw[] * range 1+get_gw[] c.line[x,0 x,c.size[1]] end nil
  each y in get_ch[] * range 1+get_gh[] c.line[0,y c.size[0],y] end nil
 end
 if cursor.value
  xy:curXY.data  cwh:get_cwh[]
  c.brush: c.pattern:1  c.box[xy*cwh 1+cwh]
  c.brush: 0 c.pattern:32 c.box[xy*cwh cwh]
 end
end
on drag xy do click[xy] end
on click xy do
 set_cxy[floor xy/get_cwh[]]
 view[]
 card.event["pick" get_cxy[]]
end
{end}

