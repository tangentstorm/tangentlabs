{card:sprites}
image:"%%"
script:"sprites.0"
{widgets}
gp:{"type":"contraption","size":[128,128],"pos":[192,107],"script":"sprites.1","show":"transparent","def":"gridpad","widgets":{"d":{"image":"%%"},"cellW":{},"cellH":{},"gridW":{},"gridH":{"value":31},"c":{"pattern":40,"image":"%%"},"allowDraw":{},"allowPick":{},"pen":{"value":3}}}
gs:{"type":"contraption","size":[129,129],"pos":[28,107],"locked":1,"show":"transparent","def":"gridSelector","widgets":{"cellW":{"pos":[159,-46],"value":8},"cellH":{"pos":[159,-3],"value":8},"c":{"size":[129,129]},"gridColor":{"size":[54,26],"pos":[159,40],"value":1},"curXY":{"pos":[159,82],"value":"[3,0]"}}}
notes:{"type":"field","size":[452,49],"pos":[24,277],"pattern":42,"style":"plain","value":"Demo of using the gridSelector and gridpad contraptions. (Probably these should be unified)\n"}
pal:{"type":"contraption","size":[129,24],"pos":[28,62],"script":"sprites.2","def":"gridSelector","widgets":{"cellW":{"pos":[159,-46],"value":8},"cellH":{"size":[54,7],"pos":[159,-3],"value":8},"c":{"size":[129,24]},"gridColor":{"size":[54,4],"pos":[159,8],"value":1},"curXY":{"size":[61,4],"pos":[159,15],"value":"[3,0]"}}}

{script:sprites.0}
on pick xy do
 gp.paste[card.image.copy[me.pos + (me.cwh * xy) me.cwh]]
end


{end}

{script:sprites.1}
on draw_cell c xy v cwh do
 c.brush: c.pattern: v
 c.rect[cwh*xy cwh]
end

on draw do
 card.image:card.image.paste[gp.d.copy[0,0 gs.cwh] gs.pos + (gs.cwh * gs.xy)]
end
{end}

{script:sprites.2}
on draw c do
 cwh:me.cwh i:-1
 each xy in me.gw cross me.gh
  c.pattern:i:i+1 c.rect[cwh*xy cwh]
 end
end

on pick xy i do
 gp.pen: me.cur
end
{end}

{card:card1}

{card:vgafont}
script:"vgafont.0"
{widgets}
font:{"type":"field","size":[264,112],"pos":[16,344],"scroll":194,"value":"%%"}
ord:{"type":"slider","size":[264,16],"pos":[16,56],"script":"vgafont.1","interval":[0,255],"value":153}
glyph:{"type":"canvas","size":[128,256],"pos":[152,80],"script":"vgafont.2","image":"%%IMG3AAgAEAbAl3AoFImGRqLyZWwWj08mVEqNJq3T5JW6vTa3y7B4/AoC","scale":16}
chart:{"type":"canvas","size":[128,256],"pos":[16,80],"locked":1,"script":"vgafont.3","pattern":0,"image":"%%","scale":1}
redraw:{"type":"button","size":[88,24],"pos":[16,464],"script":"vgafont.4","text":"redraw chart"}
do_rnd:{"type":"button","size":[112,24],"pos":[328,56],"script":"vgafont.5","show":"transparent","text":"screen saver","style":"check","value":0}
load:{"type":"button","size":[88,24],"pos":[112,464],"script":"vgafont.6","text":"load vga font"}
button1:{"type":"button","size":[48,24],"pos":[792,56],"script":"vgafont.7","show":"transparent","text":"clear","style":"invisible"}
cursor:{"type":"canvas","size":[8,16],"pos":[88,224],"locked":1,"script":"vgafont.2","border":0,"image":"%%IMG3AAgAEAbAkXAoNJmGRqJyZGwWj08mVEqNJq3T5JW6vTa3y7B4PAoC","scale":1}
term:{"type":"canvas","size":[512,256],"pos":[328,80],"volatile":1,"script":"vgafont.2","border":0,"scale":1}
notes:{"type":"field","size":[452,96],"pos":[24,230],"pattern":42,"style":"plain","value":"this should be updated to use gridPad"}

{script:vgafont.0}
fnt:array[font.text]
cs: 8,16
chart_gs: 16,16
term_gs: 64,16

on cwc c do # colorwrite color
  32+first extract index where value=c from "WKwrRyYGgcCbBMmk"
end

#-- manually draw a character pixel by pixel
on draw cv ch fg bg xy do
 each r y in fnt[(16*ch),16]  m:1
   each x in 7-range 8
     cv[xy+x,y]: if bits.and[m r] fg else bg end
     m:m*2
   end
 end 0
end

on redraw_chart do
 each y in range 16
  each x in range 16
   draw[chart x+y*16 fg:1 bg:0 (x,y)*8,16]
  end
 end
end

on redraw_glyph do
 blit[glyph ord.value fg:cwc.w bg:cwc.k]
 blit[cursor ord.value cwc.Y cwc.r]
end

#-- fast copy and paste with image interface
on cxy ch do   gw:chart_gs[0]  cs*(gw%ch),floor ch/gw  end

on blit cv ch fg bg xy do
 im:chart.copy[cxy[ch] cs].map[(0,1) dict bg,fg]
 cv.paste[im xy]
end

# -- "screen saver" ---
on rnd_xy xy do random[xy[0]],random[xy[1]] end
on rnd do
 each _ in range 256
  blit[term random[256] 32+random[15] 1 cs*rnd_xy[term_gs]]
 end
end

on view do
 if do_rnd.value rnd[] go[card] end
end
{end}

{script:vgafont.1}
on change val do
 cursor.pos: chart.pos+cxy[val]
 redraw_glyph[]
end
{end}

{script:vgafont.2}
on click pos do

end

on drag pos do

end

on release pos do

end
{end}

{script:vgafont.3}
on chart_index xy do
 sum xy * 1,chart_gs[0]
end

on click pos do
 xy: floor pos/cs
 cursor.pos: me.pos + cs*xy
 cursor.size: cs
 ord.value: chart_index[xy]
 redraw_glyph[]
end

on drag pos do click[pos] end
{end}

{script:vgafont.4}
on click do
 redraw_chart[]
end
{end}

{script:vgafont.5}
on click do
 go[card]
end
{end}

{script:vgafont.6}
on click do
 if t: read["array"]
  fnt:t
  font.text:t.encoded
  redraw_font[]
 end
end
{end}

{script:vgafont.7}
on click do
 c:term c.pattern:1
 c.rect[0,0 c.size]
end
{end}

{contraption:gridpad}
size:[128,128]
resizable:1
margin:[2,2,2,2]
script:"gridpad.0p"
template:"on draw_cell c xy v cwh do\n c.brush: c.pattern: v\n c.rect[cwh*xy cwh]\nend\n"
attributes:{"name":["gh","gw","ch","cw","allowPick","allowDraw","pen"],"label":["grid height","grid width","cell height","cell width","allowPick","allowDraw","pen"],"type":["number","number","number","number","bool","bool","number"]}
{widgets}
d:{"type":"canvas","size":[32,32],"pos":[-100,0],"locked":1,"show":"transparent","scale":1}
cellW:{"type":"slider","size":[52,25],"pos":[181,-27],"locked":1,"interval":[0,100],"value":16,"style":"compact"}
cellH:{"type":"slider","size":[51,25],"pos":[182,15],"locked":1,"interval":[0,100],"value":16,"style":"compact"}
gridW:{"type":"slider","size":[52,25],"pos":[181,57],"locked":1,"interval":[0,100],"value":32,"style":"compact"}
gridH:{"type":"slider","size":[54,25],"pos":[180,97],"locked":1,"interval":[0,100],"value":32,"style":"compact"}
c:{"type":"canvas","size":[128,128],"pos":[0,0],"pattern":0,"show":"transparent","brush":40,"scale":1}
allowDraw:{"type":"button","size":[71,20],"pos":[-89,-66],"locked":1,"font":"body","show":"transparent","text":"allowDraw","style":"check","value":1}
allowPick:{"type":"button","size":[71,20],"pos":[-171,-66],"locked":1,"font":"body","show":"transparent","text":"allowPick","style":"check","value":0}
pen:{"type":"slider","size":[53,25],"pos":[181,-71],"locked":1,"interval":[0,48],"style":"compact"}

{script:gridpad.0p}
# attributes
on set_gh x do gridH.value:x rebuild[] end on get_gh do gridH.value end
on set_gw x do gridW.value:x rebuild[] end on get_gw do gridW.value end
on set_ch x do cellH.value:x view[] end    on get_ch do cellH.value end
on set_cw x do cellW.value:x view[] end    on get_cw do cellW.value end
on set_pen x do pen.value:x end on get_pen do pen.value end
on set_allowPick x do allowPick.value: x end
on get_allowPick   do allowPick.value end
on set_allowDraw x do allowDraw.value: x end
on get_allowDraw   do allowDraw.value end

# get/set individual pixels
on get xy   do d[xy]     end   on get_get do get end
on set xy v do d[xy]:v v end   on get_set do set end

# copy/paste from image d
on get_d do d.copy[] end
on copy p s a do  d.copy[p s a] end          on get_copy do copy end
on paste i p t do d.paste[i p t] view[] end  on get_paste do paste end

c.size: card.size
gwh: (gw:gridW.value), gh:gridH.value
cwh: (cw:cellW.value), ch:cellH.value

on change do rebuild[] end # change handler for prototype widgets

on rebuild do d.size:gwh view[] end
on draw_cell xy v do
  c.pattern: v c.rect[cwh*xy cwh]
  card.event["draw_cell" c xy v cwh]
end
on view do
 each xy in (range gw) cross (range gh) draw_cell[xy d[xy]] end
 nil
end

# mouse handler
on c2xy pos do floor pos / cwh end
on click pos do xy: c2xy[pos]
 if allowPick.value pen.value: get[xy] card.event["pick" pen.value] end
 drag[pos]
end
on drag pos do xy:c2xy[pos]
 if allowDraw.value draw_cell[xy set[xy pen.value]] card.event["draw"] end
end

{end}

{contraption:gridSelector}
size:[128,128]
resizable:1
margin:[2,1,2,2]
script:"gridSelector.0p"
attributes:{"name":["cw","ch","gc","border"],"label":["cell width","cell height","grid color","draw border?"],"type":["number","number","number","bool"]}
{widgets}
cellW:{"type":"slider","size":[54,25],"pos":[158,-46],"locked":1,"interval":[4,100],"value":16,"style":"compact"}
cellH:{"type":"slider","size":[54,25],"pos":[158,-3],"locked":1,"interval":[4,100],"value":16,"style":"compact"}
c:{"type":"canvas","size":[128,128],"pos":[0,0],"locked":1,"volatile":1,"script":"gridSelector.1p","pattern":32,"show":"transparent","border":1,"scale":1}
gridColor:{"type":"slider","size":[54,25],"pos":[158,40],"locked":1,"interval":[0,47],"value":9,"style":"compact"}
curXY:{"type":"field","size":[61,20],"pos":[158,81],"locked":1,"style":"plain","value":"[0,0]"}

{script:gridSelector.0p}
on get_cw do cellW.value end       on set_cw x do cellW.value: x end
on get_ch do cellH.value end       on set_ch x do cellH.value: x end
on get_gc do gridColor.value end   on set_gc x do gridColor.value: x end
on get_border do c.border end      on set_border x do c.border:x end
on get_cxy do curXY.data end       on set_cxy xy do curXY.data: xy end

on get_gw do c.size[0]/cellW.value end
on get_gh do c.size[1]/cellH.value end
on get_cwh do cellW.value,cellH.value end
on get_cur do (get_gw[] * last curXY.data) + first curXY.data end

on view do
 c.clear[] c.brush:0
 # give instances a chance to draw on canvas
 card.event["draw" c]
 if c.pattern: gridColor.value
  each x in get_cw[] * range 1+get_gw[] c.line[x,0 x,c.size[1]] end nil
  each y in get_ch[] * range 1+get_gh[] c.line[0,y c.size[0],y] end nil
 end
 xy:curXY.data  cwh:get_cwh[]
 c.brush: c.pattern:1  c.box[xy*cwh 1+cwh]
 c.brush: 0 c.pattern:32 c.box[xy*cwh cwh]
end

on click xy do
 set_cxy[floor xy/get_cwh[]]
 view[]
 card.event["pick" get_cxy[]]
end
{end}

{script:gridSelector.1p}
# empty script to disable drawing
on drag do end

{end}

