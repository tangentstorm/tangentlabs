{script:game tree.0}
on view do
 mp:pointer.pos - c.pos
 t:g.value c.clear[] c.brush:4
 each i in range count t
  xy:t.x[i],t.y[i]
  c.pattern: if 5>mag xy-mp 32 else 45 end
  c.line[xy]
 end
end
{end}

