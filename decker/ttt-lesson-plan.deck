{script:2. my strategy.0}
on replay moves do
 b.state: s:"........." w:"x"
 each m in moves
  if m in "012345678"
   s[0+m]:w w:"xo"[w="x"] # toggle
  end
 end
 b.state:s
end

{end}

{script:2. my strategy.1}
on change val do
 replay[val]
end

on run text do
 replay[text]
end

{end}

{script:2. my strategy.2}
on change val do
 replay[me.value limit game.text]
end
{end}

