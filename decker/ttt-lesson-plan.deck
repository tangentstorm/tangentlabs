{script:valid moves.0}
turn: count game.text
who: if turn=9 "." else "xo"[2%turn] end


on view do
 co.show:"none" cx.show:"none"
 if who="." turnIcon.clear[]
 else
  turnIcon.paste[deck.contraptions.ticTacToe.widgets["c%s" format who].copy[]]
 end
 
 state.text: s: b.state
 each i in range 9
  w:card.widgets["b%i" format i]
  w.hl:i
  w.show:if s[i]="."
   si:s w.state:si[i]:who
   state"solid"
  else "none" end
 end
end
{end}

{script:valid moves.1}
on change val do
 b.state:val view[]
end
{end}

{card:4. expert system}
