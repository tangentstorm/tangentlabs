{deck}
version:1
card:0
size:[512,342]
script:"0"
name:"tic-tac-toe.deck"

{script:0}
on l ...xs do xs end # list constructor
on fac n do prod n-range n end # factorial
on nck n k do (prod n-range k) / fac[k] end # n choose k

on navigate dir do
 if dir="left" go["Prev" "SlideRight" 15]
 elseif dir="right" go["Next" "SlideLeft" 15] end
end

on run text do
 scope:deck.card.widgets
 scope.card:deck.card
 r:eval[deck.card.script scope 1]
 if r.error
  alert[r.error]
 else
  scope:r.vars
  r:eval[text scope 1]
 end
 if "res" in keys scope
   scope.res.data: r.value unless r.error
 end
end

{end}

{card:0. intro}
