field1:{"type":"field","size":[133,151],"pos":[199,159],"locked":1,"show":"invert","border":0,"scrollbar":0,"value":{"text":["","Decker Starfield Demo","\n\nUses a grid widget to track the position, velocity, brush, and pattern for each star.\n\nThis same technique can be used to make any other particle effect.\n\nPress ^E to see the code and make it your own!"],"font":["","menu",""],"arg":["","",""]}}

{script:home.0}
# decker starfield demo by tangentstorm
# (with help from internet janitor!)

# c is a canvas widget that covers the whole card.
# ns is "number of stars"
c.scale:1 w:c.size[0] h:c.size[1] ns:100

# grid1 contains the data for each star.
# clicking the button triggers this rebuild of the table.
# 
# x,y : position
# v   : velocity
# b   : brush number used to draw the star
# p   : pattern (color) used to draw the star
on rebuild do
  grid1.value: table each in range ns
    s: nil # create an empty structure (not strictly necessary)
    s.x: random[w]
    s.y: random[h]
    s.v: 1+random[5]
    s.b: random[2]
    s.p: 32+random[16]
  end
  # a more compact way to write the same thing:
  # grid1.value: table ("x","y","v","b","p") dict flip each in range ns
  #   random[w],random[h],(1+random[5]),random[2],32+random[16]
  # end
end

# widget c is marked as "animated" so decker issues
# a "view" event 60 times a second.
on view do
  # -- "physics" ----------------------------
  # store table in local variable so it's easier to work with:
  stars:grid1.value

  # move each star according to its velocity.
  # tables let us do this with a single "+" operation.
  # If you prefer, you could break "v" into separate "dx" and "dy"
  # columns, and then update x and y independently.
  stars.x: stars.x + stars.v
  
  # if a star moves off the canvas, wrap it back around 
  # to the left. the "update ... where ... from ..."
  # pattern makes it easy to modify only the stars we care about.
  stars:update x:0 y:random[c.size[1]] where x>c.size[0] from stars
  
  # save the data back to the grid widget so we can find it next frame:
  grid1.value:stars

  # -- drawing -----------------------------
  # fill canvas with pattern 1 (solid black)
  c.pattern:1 c.rect[0,0 c.size] c.pattern:0

  each s in rows stars
    c.pattern: s.p
    c.brush: s.b
    c.line[s.x,s.y] # line[] with no w/h draws a single dot
  end
end
{end}

{script:home.1}
on click row do
 # nothing. just stop canvas click from rebuilding stars
end
{end}

{script:home.2}
on click do
 rebuild[]
end
{end}

