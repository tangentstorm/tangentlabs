{deck}
version:1
card:1
size:[512,342]
name:"bex-graph.deck"
patterns:"%%"

{card:home}

{card:card1}
image:"%%"
script:"card1.0"
{widgets}
x0:{"type":"button","size":[24,20],"pos":[24,80],"font":"mono","text":"x0","shortcut":"0"}
g:{"type":"canvas","size":[18,18],"pos":[24,40],"pattern":32,"show":"transparent","image":"%%IMG2ABIAEiD/IEU=","draggable":1,"scale":1}
c:{"type":"canvas","size":[126,18],"pos":[24,104],"image":"%%","scale":1}
canvas1:{"type":"canvas","size":[126,18],"pos":[24,104],"image":"%%","scale":1}
notes:{"type":"field","size":[452,96],"pos":[24,230],"script":"card1.1","pattern":42,"style":"plain","value":"# edit the prototype\n\narne: \"ffffff 493c2b be2633 e06f8b 9d9d9d a46422 eb8931 f7e26b 1b2632 2f484e 44891a a3ce27 005784 31a2f2 b2dcef 000000\"\neach rgb i in extract \"%H\" parse value from \" \" split pal: arne\n  patterns[32+i]: rgb\nend"}

{script:card1.0}
HI:32 LO:44 # colors in arne palette
on click do
  if me.name[0]="x"
    me.pattern: if me.pattern=HI LO else HI end
    me.show: if me.pattern=LO "invert" else "solid" end
  end
end
{end}

{script:card1.1}
on run text do eval[text 0 1] end

{end}

{contraption:bex}
size:[240,100]
resizable:1
margin:[2,2,3,3]
image:"%%IMG2APAAZCz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LP8s/yz/LB4="
script:"bex.0p"
{widgets}
g:{"type":"canvas","size":[126,18],"pos":[-120,-80],"pattern":32,"show":"transparent","image":"%%","brush":32,"scale":1}
edges:{"type":"grid","size":[100,50],"pos":[260,-10],"value":{"src":["1","2"],"dst":["3","3"]},"row":1}
x0:{"type":"button","size":[24,20],"pos":[32,-48],"font":"mono","text":"x0","shortcut":"0"}
n0:{"type":"canvas","size":[18,18],"pos":[8,-48],"pattern":32,"image":"%%IMG2ABIAEiD/IEU=","scale":1}
c:{"type":"canvas","size":[240,100],"pos":[0,0],"script":"bex.1p","pattern":42,"show":"transparent","image":"%%","scale":1}
nodes:{"type":"grid","size":[104,120],"pos":[-120,-16],"format":"iiii","value":{"i":[1,2,3,4,5,6,7,8],"t":[6,3,6,4,5,6,0,1],"x":[10,36,56,69,109,118,137,174],"y":[19,55,33,54,33,52,39,65]},"row":8}
d:{"type":"canvas","size":[126,18],"pos":[80,-48],"image":"%%","scale":1}
id:{"type":"slider","size":[100,25],"pos":[-88,128],"interval":[0,1024],"value":8,"style":"compact"}
clear:{"type":"button","size":[60,20],"pos":[243,-73],"script":"bex.2p"}
dragging:{"type":"slider","size":[100,25],"pos":[-91,164],"interval":[-1,1000],"style":"compact"}

{script:bex.0p}
sz:18,18
on next_id do id.value: 1+i:id.value end
on add_node pos t do
 n: "xy" dict pos
 n.t:random[7] unless t
 n.i:next_id[]
 nodes.row: count nodes.value: nodes.value,table n
 view[]
end
on view do sz:18,18
 c.clear[]
 each r in rows nodes.value
  c.paste[g.copy[(r.t*18),0 sz] r.x,r.y 1]
 end
end

{end}

{script:bex.1p}
on click pos do
 hit: -1 unless first extract index
  where value < first sz from 
   each r in rows nodes.value
    mag pos - r.x,r.y
   end
 if hit > -1 nodes.row: hit
 else
  add_node[pos - sz/2]
 end
end

on drag pos do
 nodes.value: update x:pos[0] y:pos[1] where index=nodes.row from nodes.value
 view[]
end

on release pos do
 
end
{end}

{script:bex.2p}
on click do
 id.value:0
 nodes.value: select where 0 from nodes.value
 view[]
end

{end}

