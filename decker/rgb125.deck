{deck}
version:1
card:1
size:[512,342]
name:"rgb125.deck"
patterns:"%%"

{card:home}

{card:cube}
image:"%%"
script:"cube.0"
{widgets}
field1:{"type":"field","size":[473,108],"pos":[21,215],"style":"code","value":"each i in range 5\n px[(2+i),8 i,i,i]\nend"}
red:{"type":"slider","size":[86,25],"pos":[217,57],"interval":[0,4],"value":4,"style":"compact"}
grn:{"type":"slider","size":[86,25],"pos":[218,92],"interval":[0,4],"value":4,"style":"compact"}
blu:{"type":"slider","size":[86,25],"pos":[218,130],"interval":[0,4],"value":4,"style":"compact"}
c:{"type":"canvas","size":[89,50],"pos":[20,27],"border":0,"image":"%%","scale":1}
button1:{"type":"button","size":[60,20],"pos":[220,178],"script":"cube.1","text":"cube"}
p:{"type":"canvas","size":[30,30],"pos":[320,57],"image":"%%IMG3AAMAAwZAl0k1dKmEQQ==","scale":10}
notes:{"type":"field","size":[452,96],"pos":[24,230],"pattern":42,"style":"plain","value":"rgb125: \"ffffff 666666 cccccc 660000 990000 cc0000 ff0000 006600 009900 00cc00 00ff00 000066 000099 0000cc 0000ff 000000\"\n# extractor:   \" \" fuse each i in 32 + range 16 \"%06h\" format patterns[i] end\neach rgb i in extract \"%H\" parse value from \" \" split pal: rgb125\n  patterns[32+i]: rgb\nend"}

{script:cube.0}
on run text do eval[text 0 1] end

# old way
on old_px xy rgb do
 each v i in rgb
  c.pattern: if v v+34+4*i else 1 end
  c.rect[(xy*3)+(i,0) 1,3]
 end
 nil
end

# new way
im:image[3,3]
pixels: "%j" parse "[[2,0,1],[0,1,2],[1,2,0]]"
#pixels: "%j" parse "[[0,1,2],[0,1,2],[0,1,2]]"

on px xy rgb do
 im.pixels: pixels
 #im.transform[random["horiz","vert","flip"]]#,"left","right","turn"]]
 #im.translate[random @ 3,3 1]
 p:im.map[(0,1,2) dict each v i in rgb if v v+34+4*i else 47 end end]
 c.paste[p (xy*3) 0]
end

on change do
 if me.type ~ "slider"
  c.pattern:1 c.clear[] c.fill[]
  rgb:each w i in "red","grn","blu" card.widgets[w].value end
  each xy in 32 cross 32
   i:image[3,3]
   i.pixels:pixels
   m:i.map[(0,1,2) dict each v i in rgb if v v+34+4*i else 47 end end]
   p.paste[m 0,0 0]
   px[xy rgb]
  end
 end
end

{end}

{script:cube.1}
on click do
 each r in range 5
  each g in range 5
   each b in range 5
     x: g+r*5
     y: b
     px[x,y r,g,b]
   end
  end
 end
end
{end}

