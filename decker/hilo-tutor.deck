{card:welcome}
image:"%%"
script:"welcome.0"
{widgets}
tutor1:{"type":"contraption","size":[512,171],"pos":[0,171],"locked":1,"def":"tutor","widgets":{"body":{"size":[210,136],"value":"This deck will teach you how to make the simple guessing game you see above.\n\nIn the game, the computer will think of a secret number, and you will try to guess it. After each guess the computer will tell you if you are correct, too high, or too low.\n"},"nextBtn":{"size":[60,26],"pos":[445,47]},"cardName":{},"code":{"size":[218,137],"locked":1},"prevBtn":{"size":[60,27],"pos":[445,83],"show":"none"},"runBtn":{"size":[60,27],"pos":[445,131]},"next":{},"prev":{"value":"-"}}}
special:{"type":"field","size":[37,15],"pos":[466,31],"show":"none"}
secret:{"type":"slider","size":[100,25],"pos":[11,31],"volatile":1,"show":"none","interval":[0,100]}
guessBtn:{"type":"button","size":[60,20],"pos":[272,104],"text":"guess"}
guess:{"type":"contraption","size":[100,25],"pos":[158,101],"volatile":1,"show":"transparent","def":"hybridSlider","widgets":{"compact":{},"bar":{}}}
remaining:{"type":"slider","size":[175,25],"pos":[158,65],"locked":1,"interval":[0,7],"value":7,"format":"remaining guesses: %i","style":"bar"}
tryAgain:{"type":"button","size":[92,26],"pos":[208,137],"script":"welcome.1","pattern":39,"show":"none","text":"try again?"}
msg:{"type":"field","size":[511,20],"pos":[1,31],"script":"welcome.2","font":"menu","pattern":44,"show":"transparent","border":0,"style":"plain","align":"center","value":"guess the number"}

{script:welcome.0}
on view do reset_game[] end

on reset_game do
 guessBtn.locked:0
 tryAgain.show:"none"
 secret.value: random[100] guess.value:0
 say["guess the number"]
 remaining.value: 7
end

on say text do
 msg.text: text
end

on check do
 g: guess.value
 s: secret.value
 if g<s     say["too low"]
 elseif g>s say["too high"]
 else       say["you guessed it!"]
 end
end

on click do
 remaining.value: remaining.value - 1
 if remaining.value
  check[]
 else
  say[if guess.value=secret.value "you guessed it!" else "game over!" end]
  guessBtn.locked:1
  tryAgain.show:"solid"
 end
end


{end}

{script:welcome.1}
on click do
 reset_game[]
end
{end}

{script:welcome.2}
on change val do
 
end
{end}

